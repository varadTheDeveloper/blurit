# Postgres connection
DATABASE_URL=postgres://username:password@localhost:5432/blurit

# Port the server listens on
PORT=3000

# Moderation / limits
REPORT_THRESHOLD=5
RATE_LIMIT_MS=15000
POST_EXPIRY_HOURS=48
MAX_POST_LENGTH=500

# Secret path for the admin override endpoint - 
ADMIN_KEY=this-to-something-long-and-random
